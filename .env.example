# Copy this file to .env and fill real values BEFORE running docker compose up.
# .env is gitignored. Do NOT commit secrets.

# ---------------------------------------------------------------------------
# Database
# ---------------------------------------------------------------------------
# SQL Server SA password (must satisfy SQL Server complexity rules:
# 8+ chars, mix of upper/lower/digit/symbol).
SA_PASSWORD=ChangeMe_Strong!Passw0rd

# ---------------------------------------------------------------------------
# Auth
# ---------------------------------------------------------------------------
# JWT signing key (min 32 chars, recommended 64+ base64 chars).
# Generate with PowerShell:
#   $rng=[System.Security.Cryptography.RandomNumberGenerator]::Create()
#   $b=New-Object byte[] 48; $rng.GetBytes($b); [Convert]::ToBase64String($b)
JWT_SECRET=PASTE_GENERATED_KEY_HERE

# Javna registracija biznisa (forma /register-business). false = samo demo + kontakt.
# Za CV / test na IP-u može biti true; za ozbiljnu prodaju često false.
Auth__AllowPublicRegistration=false

# ---------------------------------------------------------------------------
# CORS (production: comma-separated list, OR pass via Cors__AllowedOrigins__N env)
# ---------------------------------------------------------------------------
# When running docker compose locally the web container talks to the API via
# the same Docker network so http://localhost:8080 is enough. In production
# set this to the full public URL of the Angular app, e.g. https://app.mojtermin.ai
CORS_ALLOWED_ORIGIN=http://localhost:8080

# ---------------------------------------------------------------------------
# Client app (used by backend to build email verification + reset links)
# ---------------------------------------------------------------------------
# The base URL of the Angular app as it is reached by end users.
# Local docker: http://localhost:8080
# Production:   https://app.mojtermin.ai
CLIENT_APP_BASE_URL=http://localhost:8080

# ---------------------------------------------------------------------------
# Email notifications (OBAVEZNO za produkciju / TikTok promet)
# ---------------------------------------------------------------------------
# NOTIFICATIONS_ENABLED=true + pun SMTP ispod. Bez toga rezervacije rade, mejl ne stiže.
#
# Preporuka: Resend (https://resend.com) + domena mojtermin.com
#   SMTP_HOST=smtp.resend.com
#   SMTP_USERNAME=resend
#   SMTP_PASSWORD=re_xxxxxxxx   (API key, ne lozinka naloga)
#   SENDER_EMAIL=noreply@mojtermin.com
# U Resend → Domains dodaj DNS zapise (DKIM CNAME + SPF TXT) kod registrara domene.
# Opcionalno DMARC (TXT na _dmarc.mojtermin.com):
#   v=DMARC1; p=none; rua=mailto:dmarc@mojtermin.com
#
# Privremeno (dev): Gmail app password — Sender MORA biti ista @gmail.com adresa, ne noreply@.
#
NOTIFICATIONS_ENABLED=true
SENDER_EMAIL=noreply@mojtermin.com
SMTP_HOST=smtp.resend.com
SMTP_PORT=587
SMTP_USERNAME=resend
SMTP_PASSWORD=

# ---------------------------------------------------------------------------
# Error monitoring (Sentry — optional)
# ---------------------------------------------------------------------------
# Leave DSN empty in dev so the SDK stays uninitialised (no outbound traffic).
# Set both DSN values to your Sentry project DSN in production.
SENTRY_DSN=
SENTRY_ENVIRONMENT=production
SENTRY_TRACES_SAMPLE_RATE=0.1
